# Standard: Textdateien normalisieren, Windows-Zeilenenden
* text=auto eol=crlf

# Batch-Dateien explizit in Windows-1252 (ANSI)
*.bat text eol=crlf working-tree-encoding=Windows-1252
*.cmd text eol=crlf working-tree-encoding=Windows-1252

# PowerShell-Skripte dürfen UTF-8 sein (PowerShell versteht das)
*.ps1 text eol=crlf working-tree-encoding=UTF-8

# Log- und Textdateien: einfach CRLF, Standard-Encoding
*.log text eol=crlf
*.txt text eol=crlf